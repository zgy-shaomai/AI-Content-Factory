{
  "name": "ContentFactory Video Pipeline",
  "active": false,
  "nodes": [
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000001",
      "name": "触发器 /trigger/video",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        240,
        300
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "trigger/video",
        "responseMode": "responseNode",
        "options": {}
      },
      "webhookId": "a1f3c4e0-1111-4a01-9d11-000000000001"
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000002",
      "name": "立即返回 202",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        480,
        300
      ],
      "parameters": {
        "respondWith": "json",
        "responseCode": 202,
        "responseBody": "={{ { accepted: true, task_id: $json.body.task_id, run_id: $execution.id } }}"
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000003",
      "name": "读取商品、风格与图池",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        720,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "cred-pg-content-factory",
          "name": "Postgres - content_factory"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT t.id AS task_id, t.requested_count, COALESCE(t.parameters, '{}'::jsonb) AS task_parameters, p.id AS product_id, p.sku, p.name, p.category, p.primary_color, p.selling_points, p.target_audience AS audience, p.use_scenarios AS scenes, s.id AS style_id, jsonb_build_object('brand_colors', s.brand_colors, 'model_features', s.model_features, 'tone', s.tone, 'mood_keywords', s.mood_keywords, 'forbidden_words', s.forbidden_words, 'lighting', s.extra->>'lighting', 'composition', s.extra->>'composition', 'lens', s.extra->>'lens') AS style_json, COALESCE((SELECT json_agg(c.* ORDER BY c.created_at DESC) FROM candidates c JOIN tasks t2 ON t2.id = c.task_id WHERE t2.product_id = p.id AND c.media_type = 'image' AND c.status = 'approved'), '[]'::json) AS image_pool FROM tasks t JOIN products p ON p.id = t.product_id LEFT JOIN style_templates s ON s.id = p.style_template_id WHERE t.id = $1::uuid LIMIT 1;",
        "options": {
          "queryReplacement": "={{ [$('触发器 /trigger/video').item.json.body.task_id] }}"
        }
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000004",
      "name": "生成分镜脚本（Claude）",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        960,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-llm-provider",
          "name": "cred-llm-provider"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "={{(($env.LLM_BASE_URL || $env.NEWAPI_BASE_URL || 'https://5dock.com/v1').replace(/\\/$/, '')) + '/chat/completions'}}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => {\n  const taskParams = $json.task_parameters || {};\n  const strategy = taskParams.prompt_strategy || {};\n  const videoDefaults = taskParams.video_defaults || {};\n  const duration = Number(videoDefaults.duration || 12);\n  const sceneCount = Number(videoDefaults.scene_count || 4);\n  const latitude = strategy.creative_latitude || 'balanced';\n  return {\n    \"model\": ($env.LLM_MODEL || \"claude-sonnet-4-5-20250929\"),\n    \"temperature\": latitude === 'strict' ? 0.45 : (latitude === 'exploratory' ? 0.72 : 0.6),\n    \"max_tokens\": 4096,\n    \"response_format\": { \"type\": \"json_object\" },\n    \"messages\": [\n      {\n        \"role\": \"system\",\n        \"content\": [\n          \"You are a senior short-form commerce video director.\",\n          `Create a ${sceneCount}-scene storyboard totaling ${duration} seconds for image-to-video generation.`,\n          \"Do not hardcode any demo SKU, garment, model identity, scene, or camera style. Use only the provided product facts, approved image pool, style JSON, and prompt strategy.\",\n          \"Each scene must define first_frame, motion_beats, end_frame, product_focus, continuity_constraints, and negative_constraints.\",\n          \"Motion beats must use time ranges such as 0.0-0.8s and describe subject_motion plus camera_motion.\",\n          \"Output strict JSON only: { sku, total_duration_sec, locked_product_facts: [], scenes: [{ scene_no, duration_sec, purpose, first_frame: { subject_pose, product_visible_parts, composition, must_match_reference }, motion_beats: [{ time, subject_motion, camera_motion }], end_frame, product_focus, continuity_constraints, negative_constraints }] }.\"\n        ].join(' ')\n      },\n      {\n        \"role\": \"user\",\n        \"content\": [\n          'SKU: ' + $json.sku,\n          'Name: ' + $json.name,\n          'Category: ' + ($json.category || ''),\n          'Primary color: ' + ($json.primary_color || ''),\n          'Selling points: ' + JSON.stringify($json.selling_points || []),\n          'Scenarios: ' + JSON.stringify($json.scenes || []),\n          'Audience: ' + ($json.audience || ''),\n          'Style JSON: ' + JSON.stringify($json.style_json || {}),\n          'Task parameters: ' + JSON.stringify(taskParams),\n          'image_pool: ' + JSON.stringify($json.image_pool || [])\n        ].join('\\\\n')\n      }\n    ]\n  };\n})() }}",
        "options": {
          "timeout": 60000,
          "retry": {
            "maxTries": 2,
            "waitBetweenTries": 3000
          }
        }
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000005",
      "name": "解析分镜脚本",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const raw = $json.choices[0].message.content;\nlet sb;\ntry { sb = JSON.parse(raw); } catch (e) {\n  throw new Error('Storyboard JSON parse failed: ' + e.message);\n}\nconst source = $(\"读取商品、风格与图池\").item.json;\nconst taskParams = source.task_parameters || {};\nconst videoDefaults = taskParams.video_defaults || {};\nconst sceneCount = Number(videoDefaults.scene_count || 4);\nconst duration = Number(videoDefaults.duration || 12);\nif (!sb.scenes || sb.scenes.length !== sceneCount) {\n  throw new Error('Storyboard must have exactly ' + sceneCount + ' scenes, got ' + (sb.scenes||[]).length);\n}\nconst total = sb.scenes.reduce((a,s)=>a+Number(s.duration_sec || 0),0);\nif (Math.abs(total - duration) > 0.5) throw new Error('total_duration_sec must be ' + duration + ' +/-0.5, got ' + total);\nconst pool = source.image_pool || [];\nconst firstPoolItem = pool.length ? pool[0] : {};\nconst refUrl = firstPoolItem.oss_url || firstPoolItem.cdn_url || firstPoolItem.url || null;\nconst productJson = {\n  sku: source.sku,\n  name: source.name,\n  category: source.category,\n  primary_color: source.primary_color,\n  audience: source.audience,\n  selling_points: source.selling_points,\n  scenes: source.scenes,\n  task_parameters: taskParams\n};\nreturn sb.scenes.map((scene, idx) => ({\n  json: {\n    task_id: $(\"触发器 /trigger/video\").item.json.body.task_id,\n    sku: sb.sku || source.sku,\n    storyboard: sb,\n    scene_no: scene.scene_no || idx + 1,\n    scene_index: idx,\n    scene_json: scene,\n    reference_image_url: refUrl,\n    style_json: source.style_json,\n    product_json: productJson,\n    task_parameters: taskParams\n  }\n}));"
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000006",
      "name": "分批处理 4 个镜头",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1440,
        300
      ],
      "parameters": {
        "batchSize": 1,
        "options": {
          "reset": false
        }
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000007",
      "name": "生成首帧提示词（LLM Provider）",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1680,
        220
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-llm-provider",
          "name": "cred-llm-provider"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "={{(($env.LLM_BASE_URL || $env.NEWAPI_BASE_URL || 'https://5dock.com/v1').replace(/\\/$/, '')) + '/chat/completions'}}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => {\n  const product = $json.product_json || {};\n  const strategy = ($json.task_parameters && $json.task_parameters.prompt_strategy) || {};\n  return {\n    \"model\": ($env.LLM_MODEL || \"claude-sonnet-4-5-20250929\"),\n    \"temperature\": strategy.creative_latitude === 'strict' ? 0.32 : 0.45,\n    \"max_tokens\": 700,\n    \"messages\": [\n      {\n        \"role\": \"system\",\n        \"content\": [\n          \"You convert one storyboard scene into one first-frame image prompt for image-to-video.\",\n          \"Output English only, one prompt string only, no markdown. The prompt must describe the exact 0.0s starting frame, not a poster or mid-action pose.\",\n          \"Preserve product identity, approved style anchors, natural anatomy, safe margins, frame ratio, and the exact starting moment of the scene.\",\n          \"The first frame must contain one coherent subject, one unchanged garment, clean limbs, stable fabric structure, no extra body parts, no text overlay, no watermark, and no new logo.\",\n          \"Use supplied product/style data instead of any fixed demo garment, model, or SKU.\"\n        ].join(' ')\n      },\n      {\n        \"role\": \"user\",\n        \"content\": [\n          'Convert this storyboard scene into one first-frame image generation prompt.',\n          '[Product JSON]', JSON.stringify(product),\n          '[Scene JSON]', JSON.stringify($json.scene_json),\n          '[Style JSON]', JSON.stringify($json.style_json || {}),\n          '[Prompt Strategy]', JSON.stringify(strategy || {}),\n          '[reference image url]', ($json.reference_image_url || '')\n        ].join('\\\\n')\n      }\n    ]\n  };\n})() }}",
        "options": {
          "timeout": 60000,
          "retry": {
            "maxTries": 2,
            "waitBetweenTries": 3000
          }
        }
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000008",
      "name": "生成首帧（Image Provider）",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1920,
        220
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-image-provider",
          "name": "cred-image-provider"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "={{(($env.IMAGE_BASE_URL || $env.MEDIA_BASE_URL || $env.ARK_ENDPOINT || 'https://ark.cn-beijing.volces.com/api/v3').replace(/\\/$/, '')) + '/images/generations'}}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": {{ JSON.stringify($env.IMAGE_MODEL || $env.ARK_IMAGE_MODEL || \"doubao-seedream-4-0-250828\") }},\n  \"prompt\": $('生成首帧提示词（LLM Provider）').item.json.choices[0].message.content,\n  \"size\": \"720x1280\",\n  \"guidance_scale\": 3,\n  \"watermark\": false,\n  \"response_format\": \"url\",\n  \"reference_images\": $('分批处理 4 个镜头').item.json.reference_image_url ? [ $('分批处理 4 个镜头').item.json.reference_image_url ] : []\n}",
        "options": {
          "timeout": 120000,
          "retry": {
            "maxTries": 2,
            "waitBetweenTries": 5000
          }
        }
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000009",
      "name": "提取首帧链接",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        2160,
        220
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "ff-url-01",
              "name": "first_frame_url",
              "type": "string",
              "value": "={{ $json.data && $json.data[0] ? $json.data[0].url : ($json.url || '') }}"
            },
            {
              "id": "ff-scene-no",
              "name": "scene_no",
              "type": "number",
              "value": "={{ $('分批处理 4 个镜头').item.json.scene_no }}"
            },
            {
              "id": "ff-scene-json",
              "name": "scene_json",
              "type": "object",
              "value": "={{ $('分批处理 4 个镜头').item.json.scene_json }}"
            },
            {
              "id": "ff-task-id",
              "name": "task_id",
              "type": "string",
              "value": "={{ $('分批处理 4 个镜头').item.json.task_id }}"
            },
            {
              "id": "ff-prev-last",
              "name": "prev_last_frame_url",
              "type": "string",
              "value": "={{ $('分批处理 4 个镜头').context.prev_last_frame_url || '' }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-00000000000a",
      "name": "生成视频提示词（LLM Provider）",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2400,
        220
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-llm-provider",
          "name": "cred-llm-provider"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "={{(($env.LLM_BASE_URL || $env.NEWAPI_BASE_URL || 'https://5dock.com/v1').replace(/\\/$/, '')) + '/chat/completions'}}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => {\n  const splitItem = $(\"分批处理 4 个镜头\").item.json;\n  const product = splitItem.product_json || {};\n  const strategy = (splitItem.task_parameters && splitItem.task_parameters.prompt_strategy) || {};\n  return {\n    \"model\": ($env.LLM_MODEL || \"claude-sonnet-4-5-20250929\"),\n    \"temperature\": strategy.creative_latitude === 'exploratory' ? 0.5 : 0.38,\n    \"max_tokens\": 800,\n    \"messages\": [\n      {\n        \"role\": \"system\",\n        \"content\": [\n          \"You write stable image-to-video prompts for commercial product videos.\",\n          \"Use the first frame as visual truth. Create one continuous shot, not a montage. Describe a short opening hold, one or two small motion beats, slow camera movement, product focus, and negative constraints.\",\n          \"Hard constraints: preserve the same person, garment, color, fabric, scene, lighting, and logo policy; no jump cuts, no scene change, no fast spin, no heavy zoom, no morphing garment, no melting fabric, no duplicated body, no extra limbs, no face drift, no new object, no text overlay, no watermark.\",\n          \"Do not hardcode any demo SKU, model identity, garment details, or scene. Use Product JSON and Scene JSON only. Return one 90-150 word provider-ready prompt string, no markdown.\"\n        ].join(' ')\n      },\n      {\n        \"role\": \"user\",\n        \"content\": [\n          'Generate the image-to-video prompt for scene ' + $json.scene_no + '.',\n          '[Product JSON]', JSON.stringify(product),\n          '[Scene JSON]', JSON.stringify($json.scene_json),\n          '[Style JSON]', JSON.stringify(splitItem.style_json || {}),\n          '[Prompt Strategy]', JSON.stringify(strategy || {}),\n          '[First-frame URL is passed through image_url; do not put it into the prompt]', $json.first_frame_url || '',\n          ($json.scene_no > 1 ? '[Previous last-frame URL is passed through last_frame_image_url]\n' + ($json.prev_last_frame_url || '') : '')\n        ].join('\\\\n')\n      }\n    ]\n  };\n})() }}",
        "options": {
          "timeout": 60000,
          "retry": {
            "maxTries": 2,
            "waitBetweenTries": 3000
          }
        }
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-00000000000b",
      "name": "提交视频任务（Video Provider）",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2640,
        220
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-video-provider",
          "name": "cred-video-provider"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "={{(($env.VIDEO_BASE_URL || $env.MEDIA_BASE_URL || $env.ARK_ENDPOINT || 'https://ark.cn-beijing.volces.com/api/v3').replace(/\\/$/, '')) + '/contents/generations/tasks'}}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": {{ JSON.stringify($env.VIDEO_MODEL || $env.ARK_VIDEO_MODEL || \"doubao-seedance-1-0-pro-250528\") }},\n  \"content\": (function(){\n    const ff = $('提取首帧链接').item.json.first_frame_url;\n    const lf = $('提取首帧链接').item.json.prev_last_frame_url;\n    const sceneNo = $('提取首帧链接').item.json.scene_no;\n    const promptText = $json.choices[0].message.content;\n    const arr = [ { type: 'text', text: promptText } ];\n    if (ff) arr.push({ type: 'image_url', image_url: { url: ff }, role: 'first_frame' });\n    if (sceneNo > 1 && lf) arr.push({ type: 'image_url', image_url: { url: lf }, role: 'last_frame' });\n    return arr;\n  })()\n}",
        "options": {
          "timeout": 60000,
          "retry": {
            "maxTries": 2,
            "waitBetweenTries": 5000
          }
        }
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-00000000000c",
      "name": "等待 20 秒",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        2880,
        220
      ],
      "parameters": {
        "amount": 20,
        "unit": "seconds"
      },
      "webhookId": "a1f3c4e0-1111-4a01-9d11-00000000000c"
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-00000000000d",
      "name": "轮询视频任务（Video Provider）",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3120,
        220
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-video-provider",
          "name": "cred-video-provider"
        }
      },
      "parameters": {
        "method": "GET",
        "url": "={{(($env.VIDEO_BASE_URL || $env.MEDIA_BASE_URL || $env.ARK_ENDPOINT || 'https://ark.cn-beijing.volces.com/api/v3').replace(/\\/$/, '')) + '/contents/generations/tasks/' + $('提交视频任务（Video Provider）').item.json.id}}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-00000000000e",
      "name": "判断视频任务是否完成",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        3360,
        220
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "combinator": "or",
          "conditions": [
            {
              "id": "cond-seedance-succeeded",
              "leftValue": "={{ $json.status }}",
              "rightValue": "succeeded",
              "operator": {
                "type": "string",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            },
            {
              "id": "cond-seedance-failed",
              "leftValue": "={{ $json.status }}",
              "rightValue": "failed",
              "operator": {
                "type": "string",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ]
        }
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-00000000000f",
      "name": "提取视频链接",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        3600,
        140
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "vid-url",
              "name": "video_url",
              "type": "string",
              "value": "={{ $json.content && $json.content[0] ? $json.content[0].video_url : ($json.video_url || '') }}"
            },
            {
              "id": "vid-scene-no",
              "name": "scene_no",
              "type": "number",
              "value": "={{ $('提取首帧链接').item.json.scene_no }}"
            },
            {
              "id": "vid-task-id",
              "name": "task_id",
              "type": "string",
              "value": "={{ $('提取首帧链接').item.json.task_id }}"
            },
            {
              "id": "vid-first-frame",
              "name": "first_frame_url",
              "type": "string",
              "value": "={{ $('提取首帧链接').item.json.first_frame_url }}"
            },
            {
              "id": "vid-status",
