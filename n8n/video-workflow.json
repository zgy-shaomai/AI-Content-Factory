              "type": "string",
              "value": "={{ $json.status }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "a1f3c4e0-1111-4a01-9d11-000000000010",
      "name": "下载场景 MP4",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3840,
        140
      ],
      "parameters": {
        "method": "GET",
        "url": "={{ $json.video_url }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "data"
            }
          },
          "timeout": 120000
        }
      }
    },
