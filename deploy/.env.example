# =============================================================================
# 服装电商 AI 内容工厂 - 环境变量模板
# =============================================================================
# 用法：cp .env.example .env  &&  vim .env
# 安全：.env 必须 chmod 600；不要 commit 到 git；建议放 1Password / Vault 备份
# 标记：[必填] = 不填系统起不来；[可选] = 不填某些功能不可用
# =============================================================================


# -----------------------------------------------------------------------------
# 时区（影响 cron 触发、日志时间、N8N 显示）
# -----------------------------------------------------------------------------
# 在哪儿拿：固定值。中国大陆部署用 Asia/Shanghai。
# 必填还是可选：[必填]
TZ=Asia/Shanghai


# =============================================================================
# 1. PostgreSQL
# =============================================================================

# Postgres 数据库名
# 在哪儿拿：自定义。建议用 cf_main。
# 必填还是可选：[必填]
POSTGRES_DB=cf_main

# Postgres 用户名
# 在哪儿拿：自定义。不要用 postgres 这种弱名。
# 必填还是可选：[必填]
POSTGRES_USER=cf_user

# Postgres 密码
# 在哪儿拿：自己生成，建议 openssl rand -base64 32
# 必填还是可选：[必填]
POSTGRES_PASSWORD=CHANGE_ME_strong_random_passwd_32chars


# =============================================================================
# 2. Redis（N8N queue mode 用）
# =============================================================================

# Redis 密码
# 在哪儿拿：自己生成，openssl rand -base64 24
# 必填还是可选：[必填]
REDIS_PASSWORD=CHANGE_ME_redis_random_passwd


# =============================================================================
# 3. N8N
# =============================================================================

# N8N 加密密钥（用于加密 credentials；丢失会导致所有凭据失效）
# 在哪儿拿：自己生成 openssl rand -hex 32；生成后必须长期保存（备份到密码管理器）
# 必填还是可选：[必填] —— 切记不要事后修改
N8N_ENCRYPTION_KEY=CHANGE_ME_64hex_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# N8N 镜像版本（必须 pin；升级前先备份 PG + 导出 workflow）
# 在哪儿拿：与本交付包验证过的版本一致，升级另走变更流程
# 必填还是可选：[必填]
N8N_VERSION=1.85.4

# N8N 控制台域名（不带 https://）
# 在哪儿拿：客户域名解析到 VPS 的子域名
# 必填还是可选：[必填]
N8N_HOST=n8n.example.com

# API webhook 域名（不带 https://）
# 在哪儿拿：客户域名解析到 VPS 的子域名（与 N8N_HOST 不同子域）
# 必填还是可选：[必填]
API_HOST=api.example.com

# Caddy 申请 Let's Encrypt 证书使用的邮箱
# 在哪儿拿：客户邮箱（用于证书过期提醒）
# 必填还是可选：[必填]
ACME_EMAIL=admin@example.com


# =============================================================================
# 4. Provider Access Center（按能力路由模型）
# =============================================================================

PAC_PROFILE=cn_ecommerce_default

# 文本 LLM：OpenAI-compatible 网关即可兼容 5dock / OpenAI / DeepSeek / Qwen / Kimi / GLM / OpenRouter / LiteLLM
LLM_PROVIDER=5dock
LLM_API_KEY=sk-CHANGE_ME_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.5dock.com/v1
LLM_MODEL=claude-sonnet-4-5-20250929

# 图片/视频共享媒体网关：如果出图和视频走同一个网关，只填这一组即可
MEDIA_API_KEY=
MEDIA_BASE_URL=

# 图片生成：可单独覆盖共享媒体网关；当前直连适配 Ark / Seedream
IMAGE_PROVIDER=volcengine_ark
IMAGE_API_KEY=CHANGE_ME_volc_ark_or_media_key
IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
IMAGE_MODEL=doubao-seedream-4-0-250828

# 视频生成：可单独覆盖共享媒体网关；Runway / MiniMax / Kling / Veo 建议通过媒体网关适配
VIDEO_PROVIDER=volcengine_ark
VIDEO_API_KEY=CHANGE_ME_volc_ark_or_media_key
VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VIDEO_MODEL=doubao-seedance-1-0-pro-250528

# ASR 可选：不填时使用 storyboard 字幕兜底
ASR_PROVIDER=volcengine
ASR_API_KEY=
ASR_BASE_URL=https://openspeech.bytedance.com/api/v1/auc
ASR_MODEL=volc_auc_common

# 旧字段兼容：保留给历史脚本 / workflow fallback
NEWAPI_BASE_URL=https://api.5dock.com/v1
NEWAPI_KEY=sk-CHANGE_ME_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARK_API_KEY=CHANGE_ME_volc_ark_or_media_key
ARK_REGION=cn-beijing
ARK_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-4-0-250828
ARK_VIDEO_MODEL=doubao-seedance-1-0-pro-250528


# =============================================================================
# 5. 阿里云 OSS
# =============================================================================

# OSS Access Key ID
# 在哪儿拿：阿里云 RAM 控制台 → 用户 → AccessKey 管理（建议新建一个 RAM 子账号专用）
# 必填还是可选：[必填]
OSS_ACCESS_KEY_ID=CHANGE_ME_oss_access_key_id

# OSS Access Key Secret
# 在哪儿拿：同上（创建时一次性显示，错过要重新生成）
# 必填还是可选：[必填]
OSS_ACCESS_KEY_SECRET=CHANGE_ME_oss_access_key_secret

# OSS Bucket 名 - 原始资料桶（客户提交的产品图、参考图、对标视频）
# 在哪儿拿：OSS 控制台 → 创建 Bucket，命名规范见 archive-structure.md §2
# 必填还是可选：[必填]
OSS_BUCKET_RAW=yn-content-raw-cn-hz

# OSS Bucket 名 - 工作桶（AI 生成候选物）
# 必填还是可选：[必填]
OSS_BUCKET_WORK=yn-content-work-cn-hz

# OSS Bucket 名 - 交付桶（通过审核的最终交付物）
# 必填还是可选：[必填]
OSS_BUCKET_DELIVER=yn-content-deliver-cn-hz

# OSS 区域
# 在哪儿拿：与 Bucket 创建时选择的区域一致
# 必填还是可选：[必填]
OSS_REGION=oss-cn-hangzhou

# OSS Endpoint
# 在哪儿拿：OSS 控制台 Bucket 概览页 → 访问域名（用 内网 / 外网 Endpoint，VPS 与 OSS 同区域时优先内网）
# 必填还是可选：[必填]
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com


# =============================================================================
# 7. 飞书开放平台
# =============================================================================

# 飞书 App ID
# 在哪儿拿：开放平台 → 开发者后台 → 应用 → 凭证与基础信息
# 必填还是可选：[必填]
FEISHU_APP_ID=cli_CHANGE_ME_xxxxxxxxxx

# 飞书 App Secret
# 在哪儿拿：同上（凭证页"App Secret"）
# 必填还是可选：[必填]
FEISHU_APP_SECRET=CHANGE_ME_feishu_app_secret

# 飞书多维表 token（审核台-内容工厂的 app_token）
# 在哪儿拿：打开多维表 → URL 中的 base/{app_token}/...
# 必填还是可选：[必填]
FEISHU_BITABLE_TOKEN=CHANGE_ME_bascn_xxxxxxxxxxxxxxxxx

# 飞书告警群机器人 webhook URL
# 在哪儿拿：群设置 → 群机器人 → 添加自定义机器人 → 复制 webhook
# 必填还是可选：[必填]
FEISHU_ALERT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/CHANGE_ME


# =============================================================================
# 8. ASR（语音转写，用于视频字幕生成）
# =============================================================================

# ASR 服务商
# 在哪儿拿：根据所选方案填 aliyun / volc / openai-whisper
# 必填还是可选：[必填]
ASR_PROVIDER=volc

# ASR API Key
# 在哪儿拿：对应服务商控制台
# 必填还是可选：[必填]
ASR_API_KEY=CHANGE_ME_asr_api_key

# ASR 调用 Endpoint
# 在哪儿拿：服务商文档（火山 ASR 默认 https://openspeech.bytedance.com/api/v1/vc）
# 必填还是可选：[必填]
ASR_ENDPOINT=https://openspeech.bytedance.com/api/v1/vc


# =============================================================================
# 9. 客户 VPS / 部署元信息（部分变量被脚本读取做提示用）
# =============================================================================

# 客户简称（用于路径前缀，与 OSS Bucket 命名一致）
# 在哪儿拿：与客户约定，小写英文
# 必填还是可选：[必填]
TENANT=yn

# 客户管理员邮箱（系统重要事件抄送）
# 在哪儿拿：客户 IT / 业务负责人邮箱
# 必填还是可选：[可选]
ADMIN_EMAIL=admin@example.com

# 部署描述（用于 banner 输出）
# 必填还是可选：[可选]
DEPLOYMENT_NOTE="Content Factory v1 · YN-BRA-001 sample"
