# =============================================================================
# 本地演示版环境变量（极简版）
# =============================================================================
# 用法：
#   cp .env.local.example .env.local
#   # 把下面 6 个 CHANGE_ME 都填掉
#   docker compose -f docker-compose.local.yml --env-file .env.local up -d
# =============================================================================

# --- 3 个必填项（不填栈起不来）---
POSTGRES_PASSWORD=local_demo_pg_pwd
N8N_ENCRYPTION_KEY=CHANGE_ME_use_openssl_rand_hex_32
REDIS_PASSWORD=local_demo_redis_pwd

# --- API key：可以先留空把栈起来，等拿到再填 + docker restart cf-n8n-local ---
# 这俩没填的话，栈能起来、N8N 能进、流程能 import，但触发后调火山方舟会 401
ARK_API_KEY=
NEWAPI_KEY=

# --- 默认值（一般不用改）---
POSTGRES_DB=content_factory
POSTGRES_USER=postgres
TZ=Asia/Shanghai
NEWAPI_BASE_URL=https://5dock.com/v1
ARK_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3

# --- 本地演示可全留空（除非要演示飞书录入流程）---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_TOKEN=

# --- 本地不部署 OSS，演示用 Seedream 返回的 CDN URL 当替代 ---
# OSS 节点演示前在 N8N 里 Deactivate 即可
